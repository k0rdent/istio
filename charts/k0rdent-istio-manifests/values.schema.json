{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "propagation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "data": {
          "type": "string"
        }
      },
      "required": [
        "enabled",
        "data"
      ]
    }
  },
  "required": [
    "propagation"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "propagation": {
            "properties": {
              "enabled": {
                "const": true
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "propagation": {
            "properties": {
              "data": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  ]
}
